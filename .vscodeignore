.mocharc.yml
test/**
# Ship node_modules in full. The kit (@databricks-solutions/lakebase-app-dev-kit)
# is required at runtime by the extension and brings ~417 transitive
# dependencies (tar, octokit, pg, @databricks/appkit, find-java-home,
# tree-kill, ...). Maintaining a whitelist of every transitive package
# is brittle; one missing entry breaks the extension on fresh install
# with ERR_MODULE_NOT_FOUND. We also do NOT add blanket exclude
# patterns like node_modules/**/.github/** because they accidentally
# strip scaffolded templates the kit ships INSIDE templates/project/
# (e.g. templates/project/common/.github/workflows/{pr,merge}.yml).
# Trade VSIX size (~60 MB) for correctness.
src/**
docs/**
*.vsix
.gitignore
tsconfig.json
webpack.config.js
.claude/**
.agent-logs/**
