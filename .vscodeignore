.mocharc.yml
test/**
node_modules/**
# Externalized in webpack.config.js — must ship at runtime. Both have
# module-load-time property assignments that webpack's CJS wrapping
# can crash on. See webpack.config.js comments for details.
!node_modules/tweetsodium/**
!node_modules/tweetnacl/**
!node_modules/blakejs/**
!node_modules/adm-zip/**
# Ship the kit so scaffold.ts can resolve templates/project/ at runtime.
# Without this whitelist, the kit (and its templates/) are stripped from
# the VSIX and `Lakebase: Create Database Project` fails on a fresh
# install with "Could not locate templates/project tree relative to /Users/
# .../extensions/.../dist".
!node_modules/@databricks-solutions/lakebase-app-dev-kit/**
src/**
docs/**
*.vsix
.gitignore
tsconfig.json
webpack.config.js
.claude/**
.agent-logs/**
