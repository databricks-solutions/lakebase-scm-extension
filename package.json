          "group": "navigation@4"
        },
        {
          "command": "lakebaseSync.reviewBranch",
          "when": "scmProvider == lakebaseUnified",
          "group": "navigation@5"
        },
        {
          "command": "lakebaseSync.createUnifiedBranch",
