      "lakebaseSync.commitMenu": [
        {
          "command": "lakebaseSync.commit",
          "group": "1_commit@1"
        },
        {
          "command": "lakebaseSync.commitStaged",
          "group": "1_commit@2"
        },
        {
          "command": "lakebaseSync.commitAll",
