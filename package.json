    "configuration": {
      "title": "Lakebase SCM Extension",
      "properties": {
        "lakebaseSync.databricksHost": {
          "type": "string",
          "default": "",
          "description": "Databricks workspace URL (auto-read from .env if empty)"
        },
        "lakebaseSync.lakebaseProjectId": {
          "type": "string",
          "default": "",
          "description": "Lakebase project ID (auto-read from .env if empty)"
        },
        "lakebaseSync.autoCreateBranch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically create Lakebase branch on git checkout"
        },
        "lakebaseSync.autoRefreshCredentials": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh database credentials in background"
        },
        "lakebaseSync.migrationPath": {
          "type": "string",
          "default": "",
          "description": "Path to migration files relative to workspace root. Leave empty to auto-detect from project language (Java: src/main/resources/db/migration, Python: alembic/versions, Node.js: migrations)."
        },
        "lakebaseSync.showUnifiedRepo": {
          "type": "boolean",
          "default": true,
          "description": "Show Unified Repo in SCM"
        },
        "lakebaseSync.productionReadOnly": {
          "type": "boolean",
          "default": true,
          "description": "Prevent creating or deleting branches on the default (production) Lakebase branch"
        },
        "lakebaseSync.trunkBranch": {
          "type": "string",
          "default": "",
          "description": "Alternative git branch name to treat as 'main' (in addition to main/master). Overrides LAKEBASE_TRUNK_BRANCH from .env if both are set."
        },
        "lakebaseSync.stagingBranch": {
          "type": "string",
          "default": "",
          "description": "Git branch name to pair with the Lakebase `staging` branch. Overrides LAKEBASE_STAGING_BRANCH from .env if both are set."
        },
        "lakebaseSync.baseBranch": {
          "type": "string",
          "default": "",
          "description": "Lakebase branch id that new feature branches ALWAYS fork from. When empty (default), new branches fork from whichever Lakebase branch you were just on — git-like semantics. Set this to pin a fixed fork source (e.g. `staging` for a 3-tier promotion flow). Overrides LAKEBASE_BASE_BRANCH from .env if both are set."
        },
        "lakebaseSync.gitBranchPrefix": {
          "type": "string",
          "default": "",
          "description": "String prefix that scopes the branch-tree view to this project's git branches. Only branches whose name starts with this prefix are listed (the current branch is always shown regardless). Useful in monorepos with branches from other projects/users. Overrides LAKEBASE_GIT_BRANCH_PREFIX from .env if both are set."
        },
        "lakebaseSync.springInitializrUrl": {
          "type": "string",
          "default": "https://start.spring.io",
          "description": "Spring Initializr base URL for Java/Kotlin project generation"
        },
        "lakebaseSync.githubToken": {
          "type": "string",
          "default": "",
          "description": "Optional GitHub PAT for headless/CI use. Leave empty to use VS Code GitHub sign-in."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "prepare": "husky",
    "compile": "webpack --mode production",
    "package": "vsce package",
    "watch": "webpack --mode development --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "test": "TS_NODE_TRANSPILE_ONLY=1 mocha --require test/setup.js --require ts-node/register 'test/suite/**/*.test.ts' 'test/equivalence/**/*.test.ts' --timeout 10000",
    "test:equivalence": "TS_NODE_TRANSPILE_ONLY=1 mocha --require test/setup.js --require ts-node/register 'test/equivalence/**/*.test.ts' --timeout 10000",
    "test:integration": "TS_NODE_TRANSPILE_ONLY=1 mocha --require test/setup.js --require ts-node/register 'test/integration/**/*.test.ts' --timeout 120000",
    "test:integration:launch": "ts-node test/integration/lib/launch-cli.ts"
  },
