{
  "name": "lakebase-scm-extension",
  "displayName": "Lakebase SCM Extension",
  "description": "Unified visibility into code and database branch changes for Databricks Lakebase",
  "version": "0.5.11",
  "publisher": "kevin-hartman",
  "icon": "resources/icons/extension-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/databricks-solutions/lakebase-scm-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:lakebaseBranches",
    "onCommand:lakebaseSync.createProject",
    "onCommand:lakebaseSync.createLakebaseProject",
    "onCommand:lakebaseSync.connectWorkspace",
    "onCommand:lakebaseSync.setupCiSecrets",
    "workspaceContains:.env",
    "workspaceContains:.env.example"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lakebase-synced-scm",
          "title": "Lakebase SCM Extension",
          "icon": "resources/icons/lakebase-sidebar.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "lakebaseBranches",
        "contents": "This workspace has no Lakebase database project yet. Run the first-time setup to create one, or open an existing Lakebase-paired project.\n\n[Set Up Lakebase for This Workspace](command:lakebaseSync.createLakebaseProject)\n\n[Create New Project](command:lakebaseSync.createProject)\n\n[Learn more](https://github.com/databricks-solutions/lakebase-scm-extension#first-time-setup-existing-project)",
        "when": "!lakebaseSync.hasProjectId"
      },
      {
        "view": "lakebaseChanges",
        "contents": "No Lakebase project configured. Set one up to start tracking schema and code changes per branch.\n\n[Set Up Lakebase for This Workspace](command:lakebaseSync.createLakebaseProject)",
        "when": "!lakebaseSync.hasProjectId"
      }
    ],
    "views": {
      "lakebase-synced-scm": [
        {
          "id": "lakebaseBranches",
          "name": "Project"
        },
        {
          "id": "lakebaseChanges",
          "name": "Changes"
        },
        {
          "id": "lakebaseMigrations",
          "name": "Schema Migrations",
          "when": "!lakebaseSync.onFeatureBranch"
        },
        {
          "id": "lakebasePR",
          "name": "Pull Request",
          "when": "lakebaseSync.hasPR"
        },
        {
          "id": "lakebaseRunner",
          "name": "CI Runner"
        },
        {
          "id": "lakebaseMerges",
          "name": "Recent Merges",
          "when": "!lakebaseSync.onFeatureBranch"
        },
        {
          "id": "lakebaseGraph",
          "name": "Graph",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "lakebaseSync.showBranchStatus",
        "title": "Show Branch Status",
        "category": "Lakebase SCM"
      },
      {
        "command": "lakebaseSync.connectWorkspace",
